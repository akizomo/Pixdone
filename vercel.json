{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install && cd app && npm install",
  "buildCommand": "npm run build && cd app && npm run build",
  "outputDirectory": "app/dist",
  "rewrites": [
    { "source": "/api/link-preview", "destination": "/api/link-preview" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/app", "destination": "/api/index" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
