{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "Pixdone Design System",
    "version": "1.0.0",
    "description": "Complete design token set for Pixdone. Token layers: core (primitives) → semantic (UI meaning) → brand (Pixdone identity).",
    "prefix": "--pxd-"
  },

  "color": {
    "$type": "color",
    "core": {
      "white":   { "$value": "#FFFFFF", "$description": "Pure white" },
      "black":   { "$value": "#111111", "$description": "Near-black ink" },

      "gray0":   { "$value": "#FCFCFC" },
      "gray50":  { "$value": "#F7F7F8" },
      "gray100": { "$value": "#EFEFF1" },
      "gray200": { "$value": "#DDDEE3" },
      "gray300": { "$value": "#C7C9D1" },
      "gray400": { "$value": "#A6AAB6" },
      "gray500": { "$value": "#858B99" },
      "gray600": { "$value": "#666C7A" },
      "gray700": { "$value": "#4C5160" },
      "gray800": { "$value": "#2E3440" },
      "gray900": { "$value": "#191D24" },

      "blue300":   { "$value": "#7BB4FF" },
      "blue500":   { "$value": "#4C8DFF" },
      "blue700":   { "$value": "#2D5BDB" },

      "green300":  { "$value": "#7EE3A7" },
      "green500":  { "$value": "#35C26B" },
      "green700":  { "$value": "#1D8F4A" },

      "yellow300": { "$value": "#FFD86B" },
      "yellow500": { "$value": "#F5B82E" },
      "yellow700": { "$value": "#B78112" },

      "red300":    { "$value": "#FF9C96" },
      "red500":    { "$value": "#E85D5D" },
      "red700":    { "$value": "#B93D3D" },

      "purple300": { "$value": "#B79CFF" },
      "purple500": { "$value": "#7B61FF" },
      "purple700": { "$value": "#5B43D6" },

      "pink300":   { "$value": "#FF9DE1" },
      "pink500":   { "$value": "#F45CCB" },
      "pink700":   { "$value": "#C73CA1" },

      "cyan300":   { "$value": "#8FE7FF" },
      "cyan500":   { "$value": "#43CBEA" },
      "cyan700":   { "$value": "#2396B2" }
    },

    "semantic": {
      "surface": {
        "page":     { "$value": "#F7F7F8",               "$description": "Default page background" },
        "pageAlt":  { "$value": "#EFEFF1",               "$description": "Alternating / sidebar background" },
        "primary":  { "$value": "#FFFFFF",               "$description": "Primary card / panel surface" },
        "secondary":{ "$value": "#F7F7F8",               "$description": "Secondary/inset surface" },
        "raised":   { "$value": "#FFFFFF",               "$description": "Elevated card surface" },
        "overlay":  { "$value": "rgba(17,17,17,0.64)",   "$description": "Modal scrim / backdrop" },
        "inverse":  { "$value": "#191D24",               "$description": "Inverse dark surface" },
        "disabled": { "$value": "#DDDEE3",               "$description": "Disabled element background" }
      },
      "text": {
        "primary":   { "$value": "#191D24", "$description": "Primary readable text" },
        "secondary": { "$value": "#4C5160", "$description": "Secondary / supporting text" },
        "tertiary":  { "$value": "#666C7A", "$description": "Tertiary / metadata text" },
        "inverse":   { "$value": "#FFFFFF", "$description": "Text on dark/colored surfaces" },
        "disabled":  { "$value": "#858B99", "$description": "Disabled text" },
        "accent":    { "$value": "#5B43D6", "$description": "Branded accent / links" },
        "success":   { "$value": "#1D8F4A", "$description": "Success inline text" },
        "warning":   { "$value": "#B78112", "$description": "Warning inline text" },
        "danger":    { "$value": "#B93D3D", "$description": "Danger / error inline text" }
      },
      "border": {
        "subtle":  { "$value": "#DDDEE3", "$description": "Hairline dividers, subtle borders" },
        "default": { "$value": "#A6AAB6", "$description": "Standard component border" },
        "strong":  { "$value": "#2E3440", "$description": "High-contrast border" },
        "inverse": { "$value": "#FFFFFF", "$description": "Border on dark surfaces" },
        "focus":   { "$value": "#4C8DFF", "$description": "Focus ring color" },
        "danger":  { "$value": "#E85D5D", "$description": "Error / danger border" }
      },
      "feedback": {
        "info":    { "$value": "#4C8DFF", "$description": "Informational state" },
        "success": { "$value": "#35C26B", "$description": "Success state" },
        "warning": { "$value": "#F5B82E", "$description": "Warning state" },
        "danger":  { "$value": "#E85D5D", "$description": "Error / danger state" }
      },
      "action": {
        "primary":          { "$value": "#7B61FF" },
        "primaryHover":     { "$value": "#6B52F0" },
        "primaryPressed":   { "$value": "#5B43D6" },
        "secondary":        { "$value": "#FFFFFF" },
        "secondaryHover":   { "$value": "#F3F1FF" },
        "secondaryPressed": { "$value": "#E6E1FF" },
        "ghostHover":       { "$value": "#EFEFF1" },
        "ghostPressed":     { "$value": "#DDDEE3" },
        "disabled":         { "$value": "#C7C9D1" }
      },
      "focus": {
        "ring":       { "$value": "#4C8DFF" },
        "ringOffset": { "$value": "#FFFFFF" }
      }
    },

    "brand": {
      "pixdone": {
        "primary":    { "$value": "#7B61FF", "$description": "Pixdone brand purple" },
        "secondary":  { "$value": "#F5B82E", "$description": "Golden reward accent" },
        "reward":     { "$value": "#35C26B", "$description": "Task completion green" },
        "epic":       { "$value": "#F45CCB", "$description": "Epic / legendary pink" },
        "freeze":     { "$value": "#43CBEA", "$description": "Freeze / ice cyan" },
        "smash":      { "$value": "#FF9C96", "$description": "Smash / hit salmon" },
        "pixelInk":   { "$value": "#191D24", "$description": "Pixel-art dark ink" },
        "pixelPaper": { "$value": "#FFFFFF", "$description": "Pixel-art light paper" }
      },
      "rarity": {
        "common":    { "$value": "#A6AAB6", "$description": "Common item rarity" },
        "rare":      { "$value": "#4C8DFF", "$description": "Rare item rarity" },
        "epic":      { "$value": "#F45CCB", "$description": "Epic item rarity" },
        "legendary": { "$value": "#F5B82E", "$description": "Legendary item rarity" }
      },
      "rewardGlow": {
        "green":  { "$value": "rgba(53,194,107,0.28)",  "$description": "Green success glow" },
        "purple": { "$value": "rgba(123,97,255,0.28)",  "$description": "Purple brand glow" },
        "pink":   { "$value": "rgba(244,92,203,0.28)",  "$description": "Pink epic glow" },
        "cyan":   { "$value": "rgba(67,203,234,0.28)",  "$description": "Cyan freeze glow" }
      }
    }
  },

  "spacing": {
    "$type": "dimension",
    "0":  { "$value": "0px" },
    "1":  { "$value": "4px",  "$description": "XS – icon gap, dense padding" },
    "2":  { "$value": "8px",  "$description": "SM – tight padding" },
    "3":  { "$value": "12px", "$description": "SM+ – component inner padding" },
    "4":  { "$value": "16px", "$description": "MD – standard padding" },
    "5":  { "$value": "20px", "$description": "MD+ – card padding" },
    "6":  { "$value": "24px", "$description": "LG – section gap" },
    "8":  { "$value": "32px", "$description": "XL – large section gap" },
    "10": { "$value": "40px", "$description": "2XL – section margin" },
    "12": { "$value": "48px", "$description": "3XL – page section" },
    "14": { "$value": "56px", "$description": "4XL" },
    "16": { "$value": "64px", "$description": "5XL – hero gap" }
  },

  "layout": {
    "$type": "dimension",
    "xs":  { "$value": "4px" },
    "sm":  { "$value": "8px" },
    "md":  { "$value": "12px" },
    "lg":  { "$value": "16px" },
    "xl":  { "$value": "24px" },
    "2xl": { "$value": "32px" },
    "3xl": { "$value": "40px" },
    "grid": {
      "columns":   { "$value": "12",   "$type": "number" },
      "gutterMd":  { "$value": "16px", "$description": "Gutter ≥768px" },
      "gutterSm":  { "$value": "12px", "$description": "Gutter <768px" },
      "marginMd":  { "$value": "24px", "$description": "Page margin ≥768px" },
      "marginSm":  { "$value": "16px", "$description": "Page margin <768px" }
    },
    "breakpoint": {
      "sm":  { "$value": "480px",  "$description": "Small mobile" },
      "md":  { "$value": "768px",  "$description": "Tablet / large mobile" },
      "lg":  { "$value": "1024px", "$description": "Desktop" },
      "xl":  { "$value": "1280px", "$description": "Wide desktop" },
      "2xl": { "$value": "1440px", "$description": "Ultra-wide" }
    }
  },

  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "xs":   { "$value": "4px",    "$description": "Chips, tags" },
    "sm":   { "$value": "6px",    "$description": "Buttons, inputs" },
    "md":   { "$value": "8px",    "$description": "Cards, popovers" },
    "lg":   { "$value": "12px",   "$description": "Sheets, dialogs" },
    "xl":   { "$value": "16px",   "$description": "Large surfaces" },
    "full": { "$value": "9999px", "$description": "Pill / circular" }
  },

  "border": {
    "$type": "dimension",
    "none":   { "$value": "0px" },
    "thin":   { "$value": "1px" },
    "base":   { "$value": "2px" },
    "strong": { "$value": "3px" }
  },

  "shadow": {
    "none":             { "$value": "none" },
    "softXs":           { "$value": "0 1px 2px rgba(17,17,17,0.08)",         "$description": "Hairline elevation" },
    "softSm":           { "$value": "0 2px 6px rgba(17,17,17,0.10)",         "$description": "Card elevation" },
    "softMd":           { "$value": "0 4px 12px rgba(17,17,17,0.12)",        "$description": "Popover elevation" },
    "pixelSm":          { "$value": "2px 2px 0px rgba(25,29,36,0.92)",       "$description": "Primary button shadow" },
    "pixelMd":          { "$value": "3px 3px 0px rgba(25,29,36,0.92)",       "$description": "Hover pixel shadow" },
    "pixelLg":          { "$value": "4px 4px 0px rgba(25,29,36,0.95)",       "$description": "Large pixel shadow" },
    "pixelInset":       { "$value": "inset 2px 2px 0px rgba(255,255,255,0.12)", "$description": "Pressed inset" },
    "rewardGlowGreen":  { "$value": "0 0 0 4px rgba(53,194,107,0.18)",       "$description": "Success glow ring" },
    "rewardGlowPurple": { "$value": "0 0 0 4px rgba(123,97,255,0.18)",       "$description": "Brand glow ring" },
    "rewardGlowPink":   { "$value": "0 0 0 4px rgba(244,92,203,0.18)",       "$description": "Epic glow ring" }
  },

  "typography": {
    "fontFamily": {
      "body":    { "$value": "\"Inter\", \"Noto Sans JP\", system-ui, sans-serif", "$description": "Primary body typeface" },
      "display": { "$value": "\"Press Start 2P\", \"DotGothic16\", monospace",    "$description": "Pixel/display typeface for emphasis" },
      "mono":    { "$value": "\"JetBrains Mono\", monospace",                     "$description": "Code / technical content" }
    },
    "fontSize": {
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "14px", "$type": "dimension" },
      "md":  { "$value": "16px", "$type": "dimension" },
      "lg":  { "$value": "18px", "$type": "dimension" },
      "xl":  { "$value": "20px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "3xl": { "$value": "32px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "number" },
      "medium":   { "$value": "500", "$type": "number" },
      "semibold": { "$value": "600", "$type": "number" },
      "bold":     { "$value": "700", "$type": "number" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.2",  "$type": "number" },
      "snug":    { "$value": "1.35", "$type": "number" },
      "normal":  { "$value": "1.5",  "$type": "number" },
      "relaxed": { "$value": "1.65", "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": "-0.02em" },
      "normal": { "$value": "0em" },
      "wide":   { "$value": "0.02em" },
      "pixel":  { "$value": "0.04em", "$description": "Pixel font tracking" }
    },
    "textStyle": {
      "displayLg":  { "$description": "Hero display – pixel font 24px/1.4 ls:0.04em" },
      "displayMd":  { "$description": "Section display – pixel font 20px/1.4 ls:0.04em" },
      "headingLg":  { "$description": "H1 – Inter Bold 24px/1.35 ls:-0.02em" },
      "headingMd":  { "$description": "H2 – Inter Bold 20px/1.35 ls:-0.02em" },
      "headingSm":  { "$description": "H3 – Inter SemiBold 18px/1.4 ls:-0.01em" },
      "bodyMd":     { "$description": "Body – Inter Regular 16px/1.5" },
      "bodySm":     { "$description": "Small body – Inter Regular 14px/1.5" },
      "labelMd":    { "$description": "Label – Inter SemiBold 14px/1.35 ls:0.02em" },
      "labelSm":    { "$description": "Caption – Inter SemiBold 12px/1.35 ls:0.02em" },
      "pixelLabel": { "$description": "Pixel label – pixel font 12px/1.5 ls:0.04em" }
    }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "80ms",  "$description": "Instant micro-interactions" },
      "fast":    { "$value": "120ms", "$description": "Button press, hover" },
      "base":    { "$value": "180ms", "$description": "Standard transition" },
      "slow":    { "$value": "240ms", "$description": "Panels, sheets" },
      "slower":  { "$value": "320ms", "$description": "Page transitions" },
      "reward":  { "$value": "700ms", "$description": "Celebration animations" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)",      "$description": "General transitions" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0, 1)",         "$description": "Elements entering screen" },
      "accelerate": { "$value": "cubic-bezier(0.3, 0, 1, 1)",       "$description": "Elements leaving screen" },
      "playful":    { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)","$description": "Spring / bounce effects" },
      "press":      { "$value": "cubic-bezier(0.2, 0, 0, 1)",       "$description": "Button press response" }
    },
    "scale": {
      "press":      { "$value": "0.96", "$description": "Scale on press" },
      "hover":      { "$value": "1.01", "$description": "Subtle hover lift" },
      "rewardPop":  { "$value": "1.06", "$description": "Completion celebration" },
      "modalEnter": { "$value": "0.98", "$description": "Modal entrance scale" }
    },
    "opacity": {
      "disabled": { "$value": "0.48", "$description": "Disabled elements" },
      "muted":    { "$value": "0.72", "$description": "Secondary / muted content" }
    }
  },

  "zIndex": {
    "base":        { "$value": "0",   "$type": "number" },
    "dropdown":    { "$value": "100", "$type": "number" },
    "sticky":      { "$value": "200", "$type": "number" },
    "overlay":     { "$value": "300", "$type": "number" },
    "bottomSheet": { "$value": "400", "$type": "number" },
    "modal":       { "$value": "500", "$type": "number" },
    "toast":       { "$value": "600", "$type": "number" },
    "tooltip":     { "$value": "700", "$type": "number" }
  },

  "accessibility": {
    "tapTargetMin": { "$value": "44px", "$description": "WCAG 2.5.5 minimum touch target" },
    "focusRingWidth": { "$value": "2px", "$description": "Focus indicator ring width" },
    "focusRingOffset": { "$value": "2px", "$description": "Focus ring offset from element" },
    "minContrastBody": { "$value": "4.5", "$description": "WCAG AA minimum contrast for body text" },
    "minContrastLarge": { "$value": "3.0", "$description": "WCAG AA minimum contrast for large text (≥18px bold)" }
  }
}
